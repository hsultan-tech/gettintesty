# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Authentication (PIN for the React frontend login screen)
# Leave blank to disable auth and allow all requests through
APP_PIN=
APP_SECRET=change-me-in-production

# Path to the Fund Facts PDF (backend/fundfacts_agent.py)
# Defaults to backend/fund_facts.pdf if not set
FUNDFACTS_PDF_PATH=

# Azure OpenAI (set USE_AZURE=true to use)
USE_AZURE=false
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Azure Cosmos DB (leave empty to fall back to local JSON file)
COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
COSMOS_KEY=your-cosmos-key-here
COSMOS_DATABASE=scotiadb
COSMOS_CONTAINER=knowledge
